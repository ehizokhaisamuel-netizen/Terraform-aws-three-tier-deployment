# Terraform working directory
.terraform/
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan

# Crash logs
crash.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# IDE files
.vscode/
.idea/

# macOS
.DS_Store



